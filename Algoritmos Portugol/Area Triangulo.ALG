Algoritmo "semnome"
// Disciplina   : [Linguagem e Lógica de Programaçăo] 
// Professor   : Antonio Carlos Nicolodi 

Var

  num, ndois: inteiro
  resu: real

Inicio

 escreva("Altura:")
 leia(num)
 escreva("Base:")
 leia(ndois)
 
 resu := (num+ndois)/2
 
 escreva("O valor da Área é:",resu)






fimalgoritmo