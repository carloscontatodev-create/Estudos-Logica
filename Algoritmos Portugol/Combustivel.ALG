Algoritmo "semnome"
// Disciplina   : [Linguagem e Lógica de Programaçăo] 
// Professor   : Antonio Carlos Nicolodi 

Var

   qntcombustivel, porlitro, total: real


Inicio

      escreval("Quantos litros serăo colocados ?")
      leia(qntcombustivel)
      escreval("Valor por litro ?")
      leia(porlitro)
      
      total := qntcombustivel*porlitro
      
      escreva("O total foi de:",total)
      
      

fimalgoritmo