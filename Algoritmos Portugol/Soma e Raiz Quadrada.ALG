Algoritmo "semnome"
// Disciplina   : [Linguagem e Lógica de Programação] 
// Professor   : Antonio Carlos Nicolodi 

Var

  n1, n2: inteiro
 resul: real

Inicio

  escreva("digite o primeiro número:")
  leia(n1)
  escreva("Digite o segundo número:")
  leia(n2)
  
  resul := raizq(n1+n2)
  escreva("Resultado:", resul)



fimalgoritmo