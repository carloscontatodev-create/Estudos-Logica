Algoritmo "semnome"
// Disciplina   : [Linguagem e Lógica de Programaçăo] 
// Professor   : Antonio Carlos Nicolodi 

Var

   npi, resu: real
   raio: inteiro

Inicio

 escreva("Escreva o valor de Pi:")
 leia(npi)
 escreva("Escreva o valor do Raio:")
 leia(raio)
 
 resu := (raio^3*npi)/3*4
 escreva("Resultado:",resu)





fimalgoritmo