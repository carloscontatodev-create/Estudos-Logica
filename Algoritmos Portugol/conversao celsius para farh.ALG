Algoritmo "semnome"
// Disciplina   : [Linguagem e Lógica de Programaçăo] 
// Professor   : Antonio Carlos Nicolodi 

Var

   celsius, farh: real

Inicio

      escreva("Digite a temperatura em Celsius:")
      leia(celsius)
      
      farh := (9/5)*celsius+32
      escreva("A temperatura em Farh é:",farh)

fimalgoritmo