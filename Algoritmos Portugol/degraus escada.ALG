Algoritmo "semnome"
// Disciplina   : [Linguagem e Lógica de Programaçăo] 
// Professor   : Antonio Carlos Nicolodi 

Var

      escada, objetivo, resu, atual: inteiro


Inicio

      escreval("Digite quantos degrais possui a escada:")
      leia(escada)
      escreval("Em qual degrau vocę está ?")
      leia(atual)
      escreval("Digite em qual degrau vocę deseja subir")
      leia(objetivo)
      
      resu := escada-atual+objetivo-escada
      

      escreval("Vocę terá que subir um total de",resu," degrais")



fimalgoritmo